node_modules/
dist
dist-types
coverage/
.env
.env.local
.env.*.local
*.log
.DS_Store
.vscode/
.idea/

# Backstage
# Local config overrides — may contain tokens, never commit.
*.local.yaml
# Yarn 4 keeps its own release binary in-repo; that MUST be committed so CI and
# the Docker build resolve the same Yarn. Everything else under .yarn is not.
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.yarn/install-state.gz

# Terraform — state can hold sensitive values and is kept in S3, not here.
# terraform.tfvars IS committed on purpose: it holds no secrets, and the CI
# plan/apply jobs need it (github_owner/github_repo have no defaults, and
# create_github_oidc_provider must stay false). Never put secrets in it.
.terraform/
*.tfstate
*.tfstate.*
*.tfplan

# Separate repo (luniemma/xeta-ai-platform) checked out here; not vendored.
RTXsample/
